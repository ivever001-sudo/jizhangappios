#!/bin/sh

##############################################################################
## Gradle start up script for POSIX generated by Gradle.
##############################################################################

APP_NAME="Gradle"
APP_BASE_NAME=$(basename "$0")

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD="maximum"

warn () {
    echo "$*"
} >&2

die () {
    echo "$*"
    exit 1
} >&2

# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        JAVACMD="$JAVA_HOME/jre/sh/java"
    else
        JAVACMD="$JAVA_HOME/bin/java"
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME"
    fi
else
    JAVACMD="java"
    command -v java >/dev/null 2>&1 || die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH."
fi

# Setup the Gradle environment
CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar

# Use gradle wrapper jar from https if not present
if [ ! -f "$CLASSPATH" ] ; then
    echo "Downloading Gradle Wrapper..."
    GRADLEW_JAR_URL="https://raw.githubusercontent.com/gradle/gradle/v8.5.0/gradle/wrapper/gradle-wrapper.jar"
    mkdir -p "$(dirname "$CLASSPATH")"
    if command -v curl >/dev/null 2>&1 ; then
        curl -sSL "$GRADLEW_JAR_URL" -o "$CLASSPATH"
    elif command -v wget >/dev/null 2>&1 ; then
        wget -q "$GRADLEW_JAR_URL" -O "$CLASSPATH"
    fi
fi

# Run gradle
exec "$JAVACMD" \
    -classpath "$CLASSPATH" \
    org.gradle.wrapper.GradleWrapperMain \
    "$@"
